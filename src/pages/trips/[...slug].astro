---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TripMap from '../../components/TripMap.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const trips = await getCollection('trips');
  return trips.map((trip) => ({
    params: { slug: trip.id },
    props: { trip },
  }));
}

const { trip } = Astro.props;
const { Content, headings } = await render(trip);

const daySections = headings.filter((heading) => heading.depth === 2 && /^day\b/i.test(heading.text));
const quickFacts = [
  { label: '旅程天數', value: `${getDayCount(trip.data.startDate, trip.data.endDate)} 天` },
  { label: '城市數量', value: `${trip.data.cities?.length ?? 0} 個` },
  { label: '重點標籤', value: `${trip.data.tags?.length ?? 0} 個` },
];

function formatDateRange(start: string, end: string): string {
  const s = new Date(start);
  const e = new Date(end);
  const opts: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
  return `${s.toLocaleDateString('zh-TW', opts)} — ${e.toLocaleDateString('zh-TW', opts)}`;
}

function getDayCount(start: string, end: string): number {
  const s = new Date(start);
  const e = new Date(end);
  return Math.ceil((e.getTime() - s.getTime()) / (1000 * 60 * 60 * 24)) + 1;
}
---

<BaseLayout title={`${trip.data.title} — 旅遊紀錄`} description={trip.data.description}>
  <article class="trip-article">
    <a href={`${import.meta.env.BASE_URL}trips/`} class="back-link">&larr; 返回所有旅程</a>

    <header class="trip-header">
      <div class="trip-header-meta">
        <span>{trip.data.destination}, {trip.data.country}</span>
        <span>{getDayCount(trip.data.startDate, trip.data.endDate)} 天</span>
      </div>
      <h1>{trip.data.title}</h1>
      <p class="trip-date">{formatDateRange(trip.data.startDate, trip.data.endDate)}</p>
      <p class="trip-desc">{trip.data.description}</p>
      {trip.data.tags && trip.data.tags.length > 0 && (
        <div class="trip-tags">
          {trip.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <TripMap cities={trip.data.cities} />

    {daySections.length > 0 && (
      <nav class="day-nav" aria-label="行程日期導覽">
        <div class="day-nav-header">
          <h2 class="day-nav-title">行程導覽</h2>
          <span class="day-nav-count">{getDayCount(trip.data.startDate, trip.data.endDate)} 天 &middot; {trip.data.cities?.length ?? 0} 個城市</span>
        </div>
        <div class="day-nav-chips">
          {daySections.map((section) => {
            const dayMatch = section.text.match(/Day\s*(\d+)/i);
            const dayNum = dayMatch ? dayMatch[1] : null;
            const dayLabel = section.text.replace(/^Day\s*\d+[｜|]\s*/i, '');
            return (
              <a href={`#${section.slug}`} class="day-chip">
                {dayNum && <span class="day-chip-num">D{dayNum}</span>}
                <span class="day-chip-label">{dayLabel}</span>
              </a>
            );
          })}
        </div>
      </nav>
    )}

    <div class="trip-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .trip-article {
    max-width: 720px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .trip-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .trip-header-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .trip-header h1 {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .trip-date {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .trip-desc {
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .trip-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    background: var(--color-tag-bg);
    color: var(--color-text-light);
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.8rem;
  }

  .day-nav {
    margin-bottom: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card-bg);
    overflow: hidden;
  }

  .day-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    background: var(--color-tag-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .day-nav-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    padding: 0;
    border: none;
  }

  .day-nav-count {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .day-nav-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
  }

  .day-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 500;
    transition: all 0.15s ease;
    line-height: 1.3;
  }

  .day-chip:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .day-chip:hover .day-chip-num {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .day-chip-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .day-chip-label {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  /* === Markdown content === */

  .trip-content {
    line-height: 1.8;
  }

  /* h2 — Day 標題 */
  .trip-content :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    margin-top: 2.75rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 3px solid var(--color-accent);
    color: var(--color-text);
  }

  /* h3 — 段落標題 */
  .trip-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }

  /* h4 — 子段落 */
  .trip-content :global(h4) {
    font-size: 0.95rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .trip-content :global(ul),
  .trip-content :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }

  .trip-content :global(li) {
    margin-bottom: 0.3rem;
  }

  .trip-content :global(li)::marker {
    color: var(--color-primary);
  }

  .trip-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .trip-content :global(strong) {
    font-weight: 700;
  }

  .trip-content :global(p) {
    margin-bottom: 0.75rem;
  }

  /* 連結 */
  .trip-content :global(a) {
    color: var(--color-primary);
    border-bottom: 1px dashed var(--color-primary);
    padding-bottom: 1px;
  }

  .trip-content :global(a:hover) {
    color: var(--color-primary-light);
    border-bottom-style: solid;
  }

  /* 引用區塊 */
  .trip-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    background: var(--color-tag-bg);
    padding: 0.75rem 1.25rem;
    margin: 1rem 0;
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--color-text-light);
  }

  .trip-content :global(blockquote p) {
    margin-bottom: 0;
  }

  /* 表格 */
  .trip-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }

  .trip-content :global(th),
  .trip-content :global(td) {
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .trip-content :global(th) {
    background: var(--color-tag-bg);
    font-weight: 600;
  }

  /* 巢狀列表 */
  .trip-content :global(ul ul),
  .trip-content :global(ol ul) {
    margin-top: 0.2rem;
    margin-bottom: 0.2rem;
  }

  @media (max-width: 640px) {
    .trip-header h1 {
      font-size: 1.75rem;
    }

    .day-chip-label {
      max-width: 140px;
    }

    .trip-content :global(h2) {
      font-size: 1.2rem;
    }
  }
</style>
