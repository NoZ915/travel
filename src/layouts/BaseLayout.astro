---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = '個人旅遊紀錄 — 記錄每一段旅程的風景與回憶', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@600;700&display=swap" rel="stylesheet" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={import.meta.env.BASE_URL} class="site-logo">旅遊紀錄</a>
        <nav class="site-nav">
          <a href={import.meta.env.BASE_URL}>首頁</a>
          <a href={`${import.meta.env.BASE_URL}trips/`}>所有旅程</a>
        </nav>
      </div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} 旅遊紀錄</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #faf9f6;
    --color-text: #2c2c2c;
    --color-text-light: #6b6b6b;
    --color-primary: #c0392b;
    --color-primary-light: #e74c3c;
    --color-accent: #e8d5b7;
    --color-card-bg: #ffffff;
    --color-border: #e8e4df;
    --color-tag-bg: #f0ebe3;
    --max-width: 900px;
    --radius: 12px;
    --font-sans: 'Noto Sans TC', 'Segoe UI', system-ui, sans-serif;
    --font-serif: 'Noto Serif TC', Georgia, serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    font-size: 16px;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.8;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--color-primary-light);
  }

  img {
    max-width: 100%;
    height: auto;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-serif);
    line-height: 1.4;
  }

  ::selection {
    background: var(--color-accent);
    color: var(--color-text);
  }
</style>

<style>
  .site-header {
    background: var(--color-card-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .site-logo:hover {
    color: var(--color-primary);
  }

  .site-nav {
    display: flex;
    gap: 1.75rem;
  }

  .site-nav a {
    color: var(--color-text-light);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .site-nav a:hover {
    color: var(--color-primary);
  }

  .main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    min-height: calc(100vh - 140px);
  }

  .site-footer {
    text-align: center;
    padding: 2rem 1.5rem;
    color: var(--color-text-light);
    font-size: 0.85rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .header-inner {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
