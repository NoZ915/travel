---
import 'leaflet/dist/leaflet.css';

interface CityPoint {
  name: string;
  label?: string;
  lat: number;
  lng: number;
  note?: string;
}

interface Props {
  cities?: CityPoint[];
}

const { cities = [] } = Astro.props;
const hasCities = cities.length > 0;
---

{hasCities && (
  <section class="trip-map-section">
    <div class="trip-map-header">
      <div>
        <p class="trip-map-eyebrow">Route</p>
        <h2 class="trip-map-title">旅程地圖</h2>
      </div>
      <p class="trip-map-summary">共經過 <strong>{cities.length}</strong> 個城市</p>
    </div>

    <div class="trip-map-body">
      <div class="trip-map-container">
        <div
          class="trip-map-canvas"
          data-trip-map
          data-cities={JSON.stringify(cities)}
        ></div>
      </div>

      <ol class="trip-city-list">
        {cities.map((city, index) => (
          <li class="trip-city-item">
            <span class="trip-city-index">{index + 1}</span>
            <div class="trip-city-info">
              <h3>{city.label ?? city.name}</h3>
              {city.note && <p>{city.note}</p>}
              <a
                href={`https://www.google.com/maps?q=${city.lat},${city.lng}`}
                target="_blank"
                rel="noreferrer"
                class="trip-city-link"
              >
                Google Maps &rarr;
              </a>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}

<script>
  import '../scripts/trip-map';
</script>

<style>
  .trip-map-section {
    margin-bottom: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card-bg);
    overflow: hidden;
  }

  .trip-map-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-tag-bg);
  }

  .trip-map-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.15rem;
  }

  .trip-map-title {
    font-size: 1.3rem;
    line-height: 1.3;
    margin: 0;
    border: none;
    padding: 0;
  }

  .trip-map-summary {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .trip-map-summary strong {
    color: var(--color-primary);
    font-weight: 700;
  }

  .trip-map-body {
    display: grid;
    grid-template-columns: 1fr 280px;
  }

  .trip-map-container {
    position: relative;
  }

  .trip-map-canvas {
    width: 100%;
    height: 420px;
  }

  /* Leaflet custom marker styles */
  .trip-map-canvas :global(.trip-marker) {
    background: none;
    border: none;
  }

  .trip-map-canvas :global(.trip-marker-inner) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    box-shadow: 0 2px 8px rgba(192, 57, 43, 0.35);
    border: 2.5px solid #fff;
  }

  /* Leaflet popup override */
  .trip-map-canvas :global(.leaflet-popup-content-wrapper) {
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .trip-map-canvas :global(.leaflet-popup-tip) {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  /* City list sidebar */
  .trip-city-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--color-border);
    max-height: 420px;
    overflow-y: auto;
  }

  .trip-city-item {
    display: flex;
    gap: 0.75rem;
    padding: 0.85rem 1.15rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s ease;
  }

  .trip-city-item:last-child {
    border-bottom: none;
  }

  .trip-city-item:hover {
    background: var(--color-tag-bg);
  }

  .trip-city-index {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    margin-top: 0.1rem;
  }

  .trip-city-info {
    min-width: 0;
  }

  .trip-city-info h3 {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
  }

  .trip-city-info p {
    margin: 0.15rem 0 0;
    font-size: 0.78rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .trip-city-link {
    display: inline-block;
    margin-top: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Scrollbar */
  .trip-city-list::-webkit-scrollbar {
    width: 4px;
  }

  .trip-city-list::-webkit-scrollbar-track {
    background: transparent;
  }

  .trip-city-list::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .trip-map-body {
      grid-template-columns: 1fr;
    }

    .trip-map-canvas {
      height: 320px;
    }

    .trip-city-list {
      border-left: none;
      border-top: 1px solid var(--color-border);
      max-height: none;
    }

    .trip-map-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
