---
interface Props {
  slug: string;
  title: string;
  description: string;
  destination: string;
  country: string;
  startDate: string;
  endDate: string;
  coverImage?: string;
  tags?: string[];
}

const { slug, title, description, destination, country, startDate, endDate, coverImage, tags } = Astro.props;

function formatDateRange(start: string, end: string): string {
  const s = new Date(start);
  const e = new Date(end);
  const opts: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
  return `${s.toLocaleDateString('zh-TW', opts)} — ${e.toLocaleDateString('zh-TW', opts)}`;
}

function getDayCount(start: string, end: string): number {
  const s = new Date(start);
  const e = new Date(end);
  return Math.ceil((e.getTime() - s.getTime()) / (1000 * 60 * 60 * 24)) + 1;
}
---

<a href={`${import.meta.env.BASE_URL}trips/${slug}/`} class="trip-card">
  {coverImage ? (
    <img src={coverImage} alt={title} class="trip-card-image" />
  ) : (
    <div class="trip-card-placeholder">
      <span class="trip-card-country">{country}</span>
    </div>
  )}
  <div class="trip-card-body">
    <div class="trip-card-meta">
      <span class="trip-card-location">{destination}, {country}</span>
      <span class="trip-card-days">{getDayCount(startDate, endDate)} 天</span>
    </div>
    <h2 class="trip-card-title">{title}</h2>
    <p class="trip-card-desc">{description}</p>
    {tags && tags.length > 0 && (
      <div class="trip-card-tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
    <span class="trip-card-date">{formatDateRange(startDate, endDate)}</span>
  </div>
</a>

<style>
  .trip-card {
    display: block;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    color: var(--color-text);
  }

  .trip-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    color: var(--color-text);
  }

  .trip-card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0;
  }

  .trip-card-placeholder {
    width: 100%;
    height: 200px;
    background: var(--color-tag-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trip-card-country {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .trip-card-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .trip-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .trip-card-location {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .trip-card-days {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-light);
  }

  .trip-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .trip-card-desc {
    font-size: 0.88rem;
    color: var(--color-text-light);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .trip-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    background: var(--color-tag-bg);
    color: var(--color-text-light);
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
  }

  .trip-card-date {
    font-size: 0.78rem;
    color: var(--color-text-light);
  }
</style>
